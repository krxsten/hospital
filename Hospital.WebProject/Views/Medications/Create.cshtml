<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

        .glass-panel label,
        .glass-panel h4,
        .page-title-white {
            color: #ffffff !important;
            font-weight: 700;
        }

    .custom-input::placeholder {
        color: #ffffff !important;
    }
    .custom-input, .custom-select {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        color: #ffffff !important;
        border-radius: 12px;
        padding: 12px;
    }

        .custom-select option {
            background-color: #0f172a;
            color: #ffffff;
        }

        .custom-input:focus, .custom-select:focus {
            background-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
            outline: none;
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 40px;
        text-transform: uppercase;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary-white:hover {
            background-color: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }

    .text-danger {
        color: #ff6b6b !important;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .input-group-text {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        border-right: none !important;
        color: #ffffff !important;
    }

    .has-icon {
        border-left: none !important;
    }
</style>

@using Hospital.WebProject.ViewModels.Medication
@model MedicationCreateViewModel

@if (User.IsInRole("Admin"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white">Pharmacy Management</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-panel">
                    <h4 class="mb-4"><i class="bi bi-capsule me-2"></i>Add New Medication</h4>

                    <form asp-action="Create" method="post">

                        <div class="mb-4">
                            <label asp-for="@Model.Name" class="form-label">Medication Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                <input asp-for="@Model.Name" class="form-control custom-input has-icon" placeholder="e.g. Amoxicillin" />
                            </div>
                            <span class="text-danger" asp-validation-for="@Model.Name"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="@Model.Description" class="form-label">Clinical Description</label>
                            <textarea asp-for="@Model.Description" class="form-control custom-input" rows="3" placeholder="Briefly describe the medication's purpose..."></textarea>
                            <span class="text-danger" asp-validation-for="@Model.Description"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="@Model.SideEffects" class="form-label">Known Side Effects</label>
                            <input asp-for="@Model.SideEffects" class="form-control custom-input" placeholder="e.g. Dizziness, Nausea..." />
                            <span class="text-danger" asp-validation-for="@Model.SideEffects"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="@Model.DiagnoseID" class="form-label">Primary Indication (Diagnosis)</label>
                            <select asp-for="@Model.DiagnoseID" asp-items="ViewBag.Diagnose" class="form-select custom-select">
                                <option value="">-- Select Linked Diagnosis --</option>
                            </select>
                            <span class="text-danger" asp-validation-for="@Model.DiagnoseID"></span>
                        </div>

                        <div class="d-flex gap-3 mt-5 pt-3 border-top border-white border-opacity-25">
                            <button type="submit" class="btn btn-primary-white flex-grow-1">Add to Inventory</button>
                            <a asp-action="Index" class="btn btn-primary-white flex-grow-1">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
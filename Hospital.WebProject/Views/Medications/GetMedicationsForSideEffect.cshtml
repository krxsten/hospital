<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

    .medication-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid #ffffff;
        border-radius: 20px;
        padding: 20px;
        transition: all 0.3s ease;
        height: 100%;
    }

        .medication-card:hover {
            transform: translateY(-8px);
            background: rgba(255, 255, 255, 0.12);
            box-shadow: 0 10px 30px rgba(255,255,255,0.15);
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 10px;
        border: none;
    }

    .custom-search-input {
        height: 50px;
        border-radius: 10px;
        background: rgba(255,255,255,0.1) !important;
        color: white !important;
        border: 1px solid #ffffff !important;
    }

        .custom-search-input::placeholder {
            color: rgba(255,255,255,0.5);
        }
</style>

@using Hospital.WebProject.ViewModels.Medication
@model List<MedicationIndexViewModel>

<div class="page-header-custom text-center">
    <h2 class="page-title-white text-white">Medication Explorer</h2>
    <div class="title-divider"></div>
</div>

<div class="container pb-5">
    <div class="glass-panel mb-5">
        <form method="get" asp-controller="Medications" asp-action="GetMedicationsForSideEffect" id="searchForm">
            <div class="row g-3">
                <div class="col-md-8">
                    <input type="text" name="sideEffect" id="sideEffectInput"
                           class="form-control custom-search-input"
                           placeholder="Type a side effect..."
                           autocomplete="off" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary-white flex-grow-1" style="height: 50px;">
                        Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light d-flex align-items-center justify-content-center px-4"
                       style="height: 50px; border-radius: 10px;">
                        Back
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="row" id="medicationResults">
        @if (Model != null && Model.Any())
        {
            @foreach (var m in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="medication-card">
                        <h5 class="text-white fw-bold">@m.Name</h5>
                        <hr class="border-white opacity-25" />
                        <p class="text-white-50 mb-1 small">Diagnosis</p>
                        <p class="text-white mb-3">@m.DiagnoseName</p>
                        <p class="text-white-50 mb-1 small">Side Effects</p>
                        <p class="text-white mb-0">@m.SideEffects</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-white-50 fs-5">Start typing to explore medications.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#sideEffectInput").on("input", function () {
                var searchVal = $(this).val();

                if (searchVal.length >= 1) {
                    $.get("/Medications/GetMedicationsForSideEffect", { sideEffect: searchVal }, function (data) {
                        var resultsDiv = $("#medicationResults");
                        resultsDiv.empty();

                        if (data.length === 0) {
                            resultsDiv.append('<div class="col-12 text-center"><p class="text-white-50">No matching medications found.</p></div>');
                            return;
                        }

                        data.forEach(function (m) {
                            var card = `
                                <div class="col-md-4 mb-4">
                                    <div class="medication-card">
                                        <h5 class="text-white fw-bold">${m.name}</h5>
                                        <hr class="border-white opacity-25" />
                                        <p class="text-white-50 mb-1 small">Diagnosis</p>
                                        <p class="text-white mb-3">${m.diagnoseName || 'No Data'}</p>
                                        <p class="text-white-50 mb-1 small">Side Effects</p>
                                        <p class="text-white mb-0">${m.sideEffects}</p>
                                    </div>
                                </div>`;
                            resultsDiv.append(card);
                        });
                    });
                } else if (searchVal.length === 0) {
                    location.reload();
                }
            });
        });
    </script>
}
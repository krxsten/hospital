@using Hospital.WebProject.ViewModels.Medication
@model List<MedicationIndexViewModel>
<h2 class="text-white">Search Medications by Side Effect</h2>
<div class="mb-3">
<form method="get" asp-controller="Medications" asp-action="GetMedicationsForSideEffect">
    <input type="text" name="sideEffect" class="form-control" placeholder="Enter side effect..." required />
    <br />
    <button class="btn btn-primary">Search</button>
    <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
</form>
</div>
<hr />

@if (Model != null && Model.Any())
{
    <div class="row">
        @foreach (var m in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>@m.Name</h5>
                        <p>
                            <strong>Diagnose:</strong> @m.DiagnoseName <br />
                            <strong>Side Effects:</strong> @m.SideEffects
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model == null)
{
    <p>No medications where found.</p>
}


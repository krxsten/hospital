<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Nurse
@model NurseIndexViewModel
@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Nurses ————</h2>
    </div>
    <form asp-action="Edit" method="post">
        <div class="mb-3">
            <label asp-for="@Model.UserID" class="form-label">Nurses: </label>
            <select asp-for="@Model.UserID" asp-items="ViewBag.Nurses" class="form-select" />
            <span class="text-danger" asp-validation-for="@Model.UserID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.SpecializationId" class="form-label">Specialization: </label>
            <select asp-for="@Model.SpecializationId" asp-items="ViewBag.Specializations" class="form-select"></select>
                <span class="text-danger" asp-validation-for="@Model.SpecializationId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.ShiftId" class="form-label">Shift: </label>
            <select asp-for="@Model.ShiftId" asp-items="ViewBag.Shifts" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.ShiftId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.ImageURL" class="form-label">Upload Image: </label>
            <input asp-for="@Model.ImageURL" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.ImageURL"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-success">Update</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

        .glass-panel label,
        .glass-panel h4,
        .page-title-white {
            color: #ffffff !important;
            font-weight: 700;
        }

    .custom-input::placeholder {
        color: #ffffff !important;
    }
    .custom-input, .custom-select {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        color: #ffffff !important;
        border-radius: 12px;
        padding: 12px;
    }

        .custom-select option {
            background-color: #0f172a;
            color: #ffffff;
        }

        .custom-input:focus, .custom-select:focus {
            background-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
            outline: none;
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 40px;
        text-transform: uppercase;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary-white:hover {
            background-color: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

    .text-danger {
        color: #ff6b6b !important;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

@using Hospital.WebProject.ViewModels.Nurse
@model NurseCreateViewModel

@if (User.IsInRole("Admin"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white">Nurse Registration</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-panel">
                    <h4 class="mb-4"><i class="bi bi-person-badge me-2"></i>New Staff Profile</h4>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <input asp-for="IsAccepted" type="hidden" />
                        <div class="mb-4">
                            <label asp-for="NurseName" class="form-label">Full Name</label>
                            <input asp-for="NurseName" class="form-control custom-input" placeholder="e.g. John Doe" />
                            <span class="text-danger" asp-validation-for="NurseName"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="@Model.SpecializationID" class="form-label">Specialization</label>
                                <select asp-for="@Model.SpecializationID" asp-items="ViewBag.Specialization" class="form-select custom-select"></select>
                                <span class="text-danger" asp-validation-for="@Model.SpecializationID"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="@Model.ShiftID" class="form-label">Assigned Shift</label>
                                <select asp-for="@Model.ShiftID" asp-items="ViewBag.Shift" class="form-select custom-select"></select>
                                <span class="text-danger" asp-validation-for="@Model.ShiftID"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="@Model.Image" class="form-label">Professional Photo</label>
                            <input asp-for="@Model.Image" type="file" class="form-control custom-input" accept="image/*" />
                            <span class="text-danger" asp-validation-for="@Model.Image"></span>
                        </div>

                        <div class="d-flex gap-3 mt-5 pt-3 border-top border-white border-opacity-25">
                            <button type="submit" class="btn btn-primary-white flex-grow-1">Save Profile</button>
                            <a asp-action="Index" class="btn btn-primary-white flex-grow-1">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@using Hospital.WebProject.ViewModels.Specialization
@model SpecializationCreateViewModel

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Specializations ————</h2>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="mb-3">
            <label asp-for="SpecializationName" class="form-label"></label>
            <input asp-for="SpecializationName" class="form-control" />
            <span class="text-danger" asp-validation-for="SpecializationName"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Image" class="form-label">Upload Image:</label>

            <input asp-for="Image" type="file" accept="image/*" class="form-control" />

            <span class="text-danger" asp-validation-for="Image"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Specialization
@model SpecializationIndexViewModel

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Specializations ————</h2>
    </div>
    <form asp-action="Edit" method="post">
        <div class="mb-3">
            <label asp-for="@Model.SpecializationName" class="form-label">Name of specialization: </label>
            <input asp-for="@Model.SpecializationName" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.SpecializationName"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.ImageURL" class="form-label">Upload Image: </label>
            <input asp-for="@Model.ImageURL" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.ImageURL"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
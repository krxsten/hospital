<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Specialization
@model SpecializationIndexViewModel

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Specializations ————</h2>
    </div>
    <form asp-action="Edit" method="post">
        <div class="mb-3">
            <label asp-for="SpecializationName" class="form-label">Name of specialization: </label>
            <input asp-for="SpecializationName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ImageURL" class="form-label">Image: </label>
            <input asp-for="ImageURL" class="form-control" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
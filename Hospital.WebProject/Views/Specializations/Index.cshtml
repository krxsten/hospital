<style>
    .specialization-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: 1px solid #f1f5f9;
        background: #fff;
    }

        .specialization-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .btn-action {
        width: 110px;
        display: inline-block;
        text-align: center;
    }

    .btn-warning {
        background-color: #ffc107;
        border: none;
        color: #212529;
    }

    .btn-danger {
        background-color: #dc3545;
        border: none;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        border: none;
    }

    .btn:hover {
        filter: brightness(92%);
        transform: scale(1.02);
    }

    h4 {
        font-family: 'Segoe UI', sans-serif;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    }

    .action-bar .btn {
        font-weight: 500;
    }

    .btn-action-equal {
        width: 100px; 
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }
</style>

@using Hospital.WebProject.ViewModels.Specialization
@model List<SpecializationIndexViewModel>

<div class="container pb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Hospital Specializations</h2>
        <div class="mx-auto bg-white rounded-pill mt-2" style="height: 4px; width: 60px;"></div>
    </div>

    <div class="d-flex justify-content-end align-items-center mb-4 gap-2 action-bar">
        <a asp-action="GetSpecialization" class="btn btn-light border rounded-pill px-4">
            <i class="bi bi-search"></i> Search
        </a>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                + Add Specialization
            </a>
        }

        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden specialization-card">

                    <div class="position-relative">
                        <img src="@item.ImageURL" class="card-img-top" alt="@item.SpecializationName"
                             style="height: 250px; object-fit: cover;">

                        <div class="card-img-overlay d-flex align-items-end p-0">
                            <div class="w-100 p-3" style="background: linear-gradient(transparent, rgba(0,0,0,0.85));">
                                <h4 class="text-white fw-bold mb-0">@item.SpecializationName</h4>
                            </div>
                        </div>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="card-footer bg-white border-0 p-3 d-flex justify-content-center gap-2">
                            <div class="d-inline">
                                <a asp-action="Edit" asp-controller="Specializations" asp-route-id="@item.ID"
                                   class="btn btn-warning btn-action-equal fw-bold rounded-3">Edit</a>
                            </div>

                            <form asp-action="Delete" asp-controller="Specializations" asp-route-id="@item.ID"
                                  method="post" onsubmit="return confirm('Are you sure you want to delete this?')"
                                  class="d-inline">
                                <button type="submit" class="btn btn-danger btn-action-equal fw-bold rounded-3">Delete</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
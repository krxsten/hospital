<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Specialization
@model List<SpecializationViewModel>

<div class="mb-3">
    <h2 style="text-align:center">Specializations</h2>
</div>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th scope="col" class="text-center">Name</th>
            <th scope="col" class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody class="table-group-divider">
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SpecializationName</td>
                @if (User.IsInRole("Admin") || User.IsInRole("Nurse") || User.IsInRole("Doctor"))
                {
                    <td>
                        <a asp-action="Edit" asp-controller="Specializations"
                           asp-route-id="@item.ID"
                           class="btn btn-warning">Edit</a>
                        <form asp-action="Delete" asp-controller="Specializations"
                              asp-route-id="@item.ID"
                              method="post"
                              style="display:inline">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

<div class="mb-3" style="font-family: 'Times New Roman'; font-size: 24px">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success" style="display: inline; font-family: 'Times New Roman'; font-size: 20px">Create</a>
    }
    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary" style="display:inline; font-family: 'Times New Roman'; font-size: 20px">Back</a>
</div>
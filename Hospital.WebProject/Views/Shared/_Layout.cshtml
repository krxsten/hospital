<style>
    .main-wrapper {
        width: 100%;
        padding: 40px 80px; 
    }

    .container {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
        background: none !important;
        box-shadow: none !important;
    }

    .section {
        margin-top: 60px;
    }

    h1, h2 {
        margin-bottom: 20px;
    }

    .service-card {
        padding: 25px;
        border-radius: 15px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(8px);
        transition: 0.3s;
    }

        .service-card:hover {
            transform: translateY(-5px);
        }
    

    .brand-text {
        font-size: 1.3rem;
        letter-spacing: 1px;
        color: white;
    }

        .brand-text strong {
            color: #bbdefb;
        }
    .navbar .dropdown-menu {
        background: white !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 8px 0 !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
    }

        .navbar .dropdown-menu .dropdown-item {
            color: #0d47a1 !important;
            font-weight: 500;
            padding: 10px 20px;
        }

            .navbar .dropdown-menu .dropdown-item:hover,
            .navbar .dropdown-menu .dropdown-item:focus {
                background-color: #e3f2fd !important;
                color: #0b3c91 !important;
            }

            .navbar .dropdown-menu .dropdown-item.active,
            .navbar .dropdown-menu .dropdown-item:active {
                background-color: #bbdefb !important;
                color: #0b3c91 !important;
            }
    .navbar-nav .nav-link {
        border: 1px solid transparent; 
        border-radius: 8px;
        transition: all 0.3s ease;
        margin: 0 2px;
    }

        .navbar-nav .nav-link:hover {
            border-color: rgba(255, 255, 255, 0.5); 
            background: rgba(255, 255, 255, 0.1);
        }

    .navbar .dropdown-menu {
        border: 1px solid transparent;
        border-radius: 8px;
        margin: 2px 8px; 
        transition: all 0.2s ease;
    }

        .navbar .dropdown-menu :hover {
            border-color: #0d47a1 !important; 
            background-color: #f8f9fa !important;
        }

    .nav-link.active {
        border-color: #bbdefb !important;
    }
</style>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital.WebProject</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hospital.WebProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css">
</head>
    

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar border-bottom mb-3">
            <div class="px-5 w-100">
                <a class="navbar-brand d-flex align-items-center text-white" asp-controller="Home" asp-action="Index">
                    <svg width="32" height="32" fill="white" viewBox="0 0 24 24" style="margin-right:8px;">
                        <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z" />
                    </svg>
                    <span class="brand-text">
                        <strong>St. Anna</strong>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 nav nav-underline">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Diagnoses" asp-action="Index">Diagnoses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Specializations" asp-action="Index">Specializations</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse") || User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Checkup" asp-action="Index">
                                    Checkups
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Patients" asp-action="Index">
                                    Patients
                                </a>
                            </li>
                        }

                       
                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Medications" asp-action="Index">
                                    Medications
                                </a>
                            </li>
                        }

                       

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown text-white">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                    Admin Panel
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="PendingDoctors">Pending Doctors</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="PendingNurses">Pending Nurses</a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item dropdown text-white">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                Medical Team
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Doctors" asp-action="Index">Doctors</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Nurses" asp-action="Index">Nurses</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown text-white">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                Hospital management
                            </a>
                            <ul class="dropdown-menu">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-controller="Shifts" asp-action="Index">
                                            Shifts
                                        </a>
                                    </li>
                                }
                                @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                                User.IsInRole("Nurse"))
                                {
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-controller="Rooms" asp-action="Index">
                                            Rooms
                                        </a>
                                    </li>
                                }

                            </ul>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="main-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Times New Roman';
        background: radial-gradient(circle at top, #1e88e5, #0d47a1);
    }

    .container {
        position: relative;
        z-index: 1; 
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.25);
        color: white;
    }

    .top-header {
        padding: 20px 10px 10px 10px;
        color: white;
    }

    .logo {
        width: 70px;
        height: auto;
        margin-bottom: 10px;
    }

    .hospital-title {
        margin: 0;
        font-size: 1.8rem;
        letter-spacing: 1px;
    }

    .custom-navbar {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .nav-link {
        color: white !important;
    }

        .nav-link:hover {
            color: whitesmoke !important;
        }

    .navbar {
        position: relative;
        z-index: 1000;
    }

    .dropdown-menu {
        z-index: 2000;
        position: absolute;
    }

</style>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital.WebProject</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hospital.WebProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css">
</head>
    

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-navbar border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center text-white" asp-controller="Home" asp-action="Index">
                    <svg width="32" height="32" fill="white" viewBox="0 0 24 24" style="margin-right:8px;">
                        <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6z" />
                    </svg>
                    <span style="font-weight:600;">St. Anna</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 nav nav-underline">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Diagnoses" asp-action="Index">Diagnoses</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Specializations" asp-action="Index">Specializations</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse") || User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Checkup" asp-action="Index">
                                    Checkups
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse") || User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Patients" asp-action="Index">
                                    Patients
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse") || User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Rooms" asp-action="Index">
                                    Rooms
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin") || User.IsInRole("Doctor") ||
                                                User.IsInRole("Nurse"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Medications" asp-action="Index">
                                    Medications
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Shifts" asp-action="Index">
                                    Shifts
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light"
                                   asp-controller="Admin" asp-action="PendingDoctors">
                                    Admin Panel
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Medical Team
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="Doctors" asp-action="Index">Doctors</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Nurses" asp-action="Index">Nurses</a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

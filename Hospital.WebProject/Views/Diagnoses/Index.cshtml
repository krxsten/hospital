<style>
    .diagnose-card {
        transition: all 0.3s ease;
        border-radius: 15px !important;
        border: 1px solid #e2e8f0 !important;
        overflow: hidden;
        background: #fff;
    }

        .diagnose-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
        }

    .diagnose-img-container {
        position: relative;
        height: 220px;
        overflow: hidden;
    }

        .diagnose-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .diagnose-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.5rem 1rem 0.5rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.85));
    }

    .btn-diag-action {
        width: 100px !important;
        height: 38px !important;
        display: inline-flex !important;
        align-items: center;
        justify-content: center;
        font-weight: 700 !important;
        border-radius: 8px !important;
        font-size: 14px !important;
        border: none !important;
        transition: filter 0.2s;
    }

    .btn-warning {
        background-color: #ffc107;
        color: #212529;
    }

    .btn-danger {
        background-color: #dc3545;
        color: white;
    }

    .btn-secondary {
        background-color: #64748b;
    }

    .section-title {
        font-family: 'Segoe UI', sans-serif;
        font-weight: 700;
        color: #0f172a;
    }

    .action-bar .btn {
        border-radius: 50px;
    }
</style>

@using Hospital.WebProject.ViewModels.Diagnose
@model List<DiagnoseIndexViewModel>

<div class="container pb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Diagnoses</h2>
        <div class="mx-auto bg-white rounded-pill mt-2" style="height: 4px; width: 60px;"></div>
    </div>
    <div class="d-flex justify-content-end align-items-center mb-4 gap-2 action-bar">

        @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
        {
            <a asp-action="Create" class="btn btn-success px-4 shadow-sm">+ Add diagnose</a>
        }
        <a asp-action="GetDiagnose" class="btn btn-light border px-4 shadow-sm">
            <i class="bi bi-search"></i> Search
        </a>

        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary px-4 shadow-sm">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 diagnose-card border-0 shadow-sm">
                    <div class="diagnose-img-container">
                        <img src="@item.ImageURL" alt="diagnose">
                        <div class="diagnose-overlay">
                            <h5 class="text-white fw-bold mb-0">@item.Name</h5>
                        </div>
                    </div>

                    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                    {
                        <div class="card-footer bg-white border-0 p-3 d-flex justify-content-center gap-2">
                            <a asp-action="Edit" asp-route-id="@item.ID"
                               class="btn btn-warning btn-diag-action">Edit</a>

                            <form asp-action="Delete" asp-route-id="@item.ID" method="post" class="m-0">
                                <button type="submit" class="btn btn-danger btn-diag-action"
                                        onclick="return confirm('Delete this record?')">
                                    Delete
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
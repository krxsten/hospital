@using Hospital.WebProject.ViewModels.Room
@model List<RoomViewModel>

@if (User.IsInRole("Admin") || User.IsInRole("Patient") || User.IsInRole("Doctor") || User.IsInRole("Nurse"))
{
    @foreach (var item in Model)
    {
        <div class="card" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title">@item.RoomNumber</h5>

                @if (item.IsTaken == true)
                {
                    <p class="card-text">Room No.@item.RoomNumber is occupied!</p>
                }
                <p class="card-text">Room No.@item.RoomNumber is not occupied!</p>
            </div>
        </div>
    }
}
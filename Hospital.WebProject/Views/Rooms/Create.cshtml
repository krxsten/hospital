<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

        .glass-panel label,
        .glass-panel h4,
        .page-title-white {
            color: #ffffff !important;
            font-weight: 700;
        }

    .custom-input::placeholder {
        color: #ffffff !important;
    }
    .custom-input {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        color: #ffffff !important;
        border-radius: 12px;
        padding: 12px;
    }

        .custom-input:focus {
            background-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
            outline: none;
        }

    .form-check-label {
        color: #ffffff !important;
        cursor: pointer;
    }

    .form-check-input {
        background-color: transparent;
        border: 1px solid #ffffff;
    }

        .form-check-input:checked {
            background-color: #ffffff;
            border-color: #ffffff;
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 40px;
        text-transform: uppercase;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary-white:hover {
            background-color: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

    .text-danger {
        color: #ff6b6b !important;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

@using Hospital.WebProject.ViewModels.Room
@model RoomCreateViewModel

@if (User.IsInRole("Admin"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white">Room Management</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="glass-panel">
                    <h4 class="mb-4"><i class="bi bi-door-open me-2"></i>Create New Room</h4>

                    <form asp-action="Create" method="post">

                        <div class="mb-4">
                            <label asp-for="@Model.RoomNumber" class="form-label">Room Number</label>
                            <input asp-for="@Model.RoomNumber" class="form-control custom-input" placeholder="e.g. 301-A" />
                            <span class="text-danger" asp-validation-for="@Model.RoomNumber"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label d-block">Initial Availability Status</label>

                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" asp-for="@Model.IsTaken" value="true" id="statusOccupied" />
                                <label class="form-check-label" for="statusOccupied">Occupied</label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="IsTaken" value="false" id="statusAvailable" checked />
                                <label class="form-check-label" for="statusAvailable">Not Occupied</label>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5 pt-3 border-top border-white border-opacity-25">
                            <button type="submit" class="btn btn-primary-white flex-grow-1">Create Room</button>
                            <a asp-action="Index" class="btn btn-primary-white flex-grow-1">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
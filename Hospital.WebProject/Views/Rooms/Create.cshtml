<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Room
@model RoomIndexViewModel

@if (User.IsInRole("Admin"))
{
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="@Model.RoomNumber" class="form-label">Room number: </label>
            <input asp-for="@Model.RoomNumber" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.RoomNumber"></span>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="radio" asp-for="@Model.IsTaken" value="true" />
            <label class="form-check-label">Occupied</label>
        </div>

        <div class="form-check">
            <input class="form-check-input" type="radio" asp-for="IsTaken" value="false" />
            <label class="form-check-label">Not occupied</label>
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
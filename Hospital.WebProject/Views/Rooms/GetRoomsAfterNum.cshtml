<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

    .room-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid #ffffff;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }

        .room-card:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 30px rgba(255, 255, 255, 0.15);
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 10px;
        border: none;
    }

    .custom-search-input {
        height: 50px;
        border-radius: 10px;
        background: rgba(255,255,255,0.1) !important;
        color: white !important;
        border: 1px solid #ffffff !important;
    }

        .custom-search-input::placeholder {
            color: rgba(255,255,255,0.5);
        }

    .badge-status {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        display: inline-block;
    }

    .status-occupied {
        background-color: #ff6b6b;
        color: #ffffff;
    }

    .status-available {
        background-color: #51cf66;
        color: #ffffff;
    }
</style>

@using Hospital.WebProject.ViewModels.Room
@model List<RoomIndexViewModel>

@if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Nurse"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white text-white">Room Directory</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="glass-panel mb-5">
            <form method="get" asp-action="GetRoomsAfterNum">
                <div class="row g-3">
                    <div class="col-md-8">
                        <input type="number" name="roomNum"
                               class="form-control custom-search-input"
                               placeholder="Enter minimum room number..." />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary-white flex-grow-1" style="height: 50px;">
                            <i class="bi bi-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-outline-light d-flex align-items-center px-4"
                           style="border-radius: 10px;">
                            Back
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="row" id="roomResultsContainer">
            @if (Model != null && Model.Any())
            {
                @foreach (var r in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="room-card p-4">
                            <h4 class="text-white fw-bold mb-3">Room @r.RoomNumber</h4>
                            <p class="mb-0">
                                @if (r.IsTaken)
                                {
                                    <span class="badge-status status-occupied">Occupied</span>
                                }
                                else
                                {
                                    <span class="badge-status status-available">Available</span>
                                }
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-white-50 fs-5">Search to view available rooms.</p>
                </div>
            }
        </div>
    </div>
}
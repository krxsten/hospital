<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Checkup
@model CheckupCreateViewModel
@if (User.IsInRole("Patient"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Check ups ————</h2>
    </div>
    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label asp-for="@Model.DoctorID" class="form-label">Doctor: </label>
            <select asp-for="@Model.DoctorID" id="DoctorID" asp-items="@ViewBag.Doctors" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.DoctorID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Date" class="form-label">Date: </label>
            <input asp-for="@Model.Date" id="Date" type="date" class="form-control" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="@Model.Date" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="@Model.Time" class="form-label">Available Time: </label>
            <select asp-for="@Model.Time" id="Time" class="form-select">
                <option>Select time</option>
                    </select>
            <span asp-validation-for="@Model.Date" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function loadSlots(){

            var doctorId = $("#DoctorID").val();
            var date = $("#Date").val();

            if(!doctorId || !date)
                return;

            $.get("/Checkup/GetAvailableSlots", {
                doctorId: doctorId,
                date: date
            }, function(data){

                $("#Time").empty();
                $("#Time").append(`<option>Select time</option>`);

                data.forEach(function(time){
                    $("#Time").append(
                        `<option value="${time}">${time}</option>`
                    );
                });

            });
        }

        $("#DoctorID").change(loadSlots);
        $("#Date").change(loadSlots);
    </script>
}
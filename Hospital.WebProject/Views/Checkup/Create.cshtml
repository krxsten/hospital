<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Checkup
@model CheckupViewModel
@if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Nurse") || User.IsInRole("Patient"))
{
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="@Model.PatientID" class="form-label">Patient: </label>
            <select asp-for="@Model.PatientID" asp-items="ViewBag.Users" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.PatientID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.DoctorID" class="form-label">Doctor: </label>
            <select asp-for="@Model.DoctorID" id="DoctorID" asp-items="ViewBag.Doctor" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.DoctorID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.Date" class="form-label">Checkup Date & Time</label>
            <input asp-for="@Model.Date" type="datetime-local" class="form-control" id="checkupDate" />
            <span class="text-danger" asp-validation-for="@Model.Date"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
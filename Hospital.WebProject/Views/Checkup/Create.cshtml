<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Checkup
@model CheckupCreateViewModel
@if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Nurse") || User.IsInRole("Patient"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Check ups ————</h2>
    </div>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="@Model.PatientID" class="form-label">Patient: </label>
            <select asp-for="@Model.PatientID" asp-items="ViewBag.Users" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.PatientID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.DoctorID" class="form-label">Doctor: </label>
            <select asp-for="@Model.DoctorID" id="DoctorID" asp-items="ViewBag.Doctor" class="form-select"></select>
            <span class="text-danger" asp-validation-for="@Model.DoctorID"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Date" class="form-label"></label>
            <input asp-for="Date" id="Date" type="date" class="form-control" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Available Time</label>

            <select asp-for="Date" id="Time" class="form-select">
                <option>Select time</option>
            </select>

            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        function loadSlots(){

            var barberId = $("#BarberId").val();

            var serviceId = $("#ServiceId").val();

            var date = $("#Date").val();

            if(!barberId || !serviceId || !date)

                return;

            $.get("/Reservations/GetAvailableSlots", {

                barberId: barberId,

                serviceId: serviceId,

                date: date

            }, function(data){

                $("#Time").empty();

                $("#Time").append(`<option>Select time</option>`);

                data.forEach(function(time){

                    $("#Time").append(

                        `<option value="${time}">${time}</option>`

                    );

                });

            });

        }

        $("#BarberId").change(loadSlots);

        $("#ServiceId").change(loadSlots);

        $("#Date").change(loadSlots);

    </script>

}

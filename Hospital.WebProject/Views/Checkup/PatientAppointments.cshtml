<style>
    .checkup-container {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 2rem;
        margin-top: 2rem;
    }

    .table {
        border-collapse: separate;
        border-spacing: 0 10px;
        border: none;
    }

        .table thead th {
            background-color: #f8fafc;
            border: none;
            color: #64748b;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
            padding: 15px;
        }

        .table tbody tr {
            background-color: white;
            transition: transform 0.2s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

            .table tbody tr:hover {
                transform: scale(1.01);
                background-color: #f1f5f9;
            }

        .table td {
            vertical-align: middle;
            border: none;
            padding: 15px;
            border-top: 1px solid #f1f5f9;
            border-bottom: 1px solid #f1f5f9;
        }

    .btn-action-sm {
        min-width: 110px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 13px;
        border-radius: 8px;
        border: none;
        transition: all 0.2s;
    }

    .btn-warning {
        background-color: #ffc107;
        color: #212529;
    }

    .btn-danger {
        background-color: #dc3545;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
    }

    .btn:hover {
        filter: brightness(90%);
    }
</style>

@using Hospital.WebProject.ViewModels.Checkup
@model List<CheckupIndexViewModel>


    <div class="container pb-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-white">Medical Appointments</h2>
            <div class="mx-auto bg-white rounded-pill mt-2" style="height: 4px; width: 60px;"></div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="checkup-container">
                <div class="table-responsive">
                    <table class="table text-center">
                        <thead>
                            <tr>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Appointment Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.PatientName</td>
                                    <td>
                                        <span class="badge bg-info text-dark rounded-pill px-3">Dr. @item.DoctorName</span>
                                    </td>
                                    <td class="text-muted">@item.Date</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info text-center rounded-4 shadow-sm">
                No checkups found.
            </div>
        }
    </div>
}
<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

    .patient-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid #ffffff;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }

        .patient-card:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 30px rgba(255, 255, 255, 0.15);
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 10px;
        border: none;
    }

    .custom-search-input {
        height: 50px;
        border-radius: 10px;
        background: rgba(255,255,255,0.1) !important;
        color: white !important;
        border: 1px solid #ffffff !important;
    }

        .custom-search-input::placeholder {
            color: rgba(255,255,255,0.5);
        }
</style>

@using Hospital.WebProject.ViewModels.Patient
@model List<PatientIndexViewModel>

@if (User.IsInRole("Admin") || User.IsInRole("Doctor") || User.IsInRole("Nurse"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white text-white">Doctor's Patient List</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="glass-panel mb-5">
            <form method="get" asp-action="PatientsWithSuchDoctor" id="searchForm">
                <div class="row g-3">
                    <div class="col-md-8">
                        <input type="text" id="patientSearchInput" name="doctorName"
                               class="form-control custom-search-input"
                               placeholder="Enter doctor's first name..."
                               autocomplete="off" />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary-white flex-grow-1" style="height: 50px;">
                            <i class="bi bi-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-outline-light d-flex align-items-center px-4"
                           style="border-radius: 10px;">
                            Back
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="row" id="patientResultsContainer">
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="patient-card p-4">
                            <h4 class="text-white fw-bold mb-3">@p.UserName</h4>
                            <p class="text-white-50 mb-2">
                                <strong class="text-white">Assigned Doctor:</strong> Dr. @p.DoctorName
                            </p>
                            <p class="text-white-50 mb-2">
                                <strong class="text-white">Admit Date:</strong> @p.HospitalizationDate
                            </p>
                            <p class="text-white-50 mb-0">
                                <strong class="text-white">Hospitalization Time:</strong> @p.HospitalizationTime
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-white-50 fs-5">Start typing to find patients by doctor.</p>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#patientSearchInput").on("input", function () {
                var searchVal = $(this).val();
                var resultsDiv = $("#patientResultsContainer");

                if (searchVal.length >= 1) {
                    $.get("/Patients/PatientsWithSuchDoctor", { doctorName: searchVal }, function (data) {
                        resultsDiv.empty();

                        if (data.length === 0) {
                            resultsDiv.append('<div class="col-12 text-center"><p class="text-white-50">No patients found for this doctor.</p></div>');
                            return;
                        }

                        data.forEach(function (p) {
                            resultsDiv.append(`
                                <div class="col-md-4 mb-4">
                                    <div class="patient-card p-4">
                                        <h4 class="text-white fw-bold mb-3">${p.userName}</h4>
                                        <p class="text-white-50 mb-2">
                                            <strong class="text-white">Assigned Doctor:</strong> Dr. ${p.doctorName}
                                        </p>
                                        <p class="text-white-50 mb-2">
                                            <strong class="text-white">Admit Date:</strong> ${p.hospitalizationDate}
                                        </p>
                                        <p class="text-white-50 mb-0">
                                            <strong class="text-white">Hospitalization Time:</strong> ${p.hospitalizationTime}
                                        </p>
                                    </div>
                                </div>
                            `);
                        });
                    });
                } else if (searchVal.length === 0) {
                    location.reload();
                }
            });
        });
    </script>
}
<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Patient
@model SelectDoctorAndRoomViewModel

@if (User.IsInRole("Patient"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Select Doctor & Room ————</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="SelectDoctorAndRoom" method="post">
        <div class="mb-3">
            <label asp-for="@Model.DoctorId" class="form-label">Doctor: </label>
            <select asp-for="@Model.DoctorId" asp-items="@ViewBag.Doctor" class="form-select">
                <option value="">-- Select a Doctor --</option>
            </select>
            <span class="text-danger" asp-validation-for="@Model.DoctorId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.RoomId" class="form-label">Room: </label>
            <select asp-for="@Model.RoomId" asp-items="@ViewBag.Room" class="form-select">
                <option value="">-- Select a Room --</option>
            </select>
            <span class="text-danger" asp-validation-for="@Model.RoomId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.BirthCity" class="form-label">Birth City: </label>
            <select asp-for="@Model.BirthCity" asp-items="@ViewBag.Cities" class="form-select">
                <option value="">-- Select a City --</option>
            </select>
            <span class="text-danger" asp-validation-for="@Model.BirthCity"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.DateOfBirth" class="form-label">Date of Birth: </label>
            <input asp-for="@Model.DateOfBirth" type="date" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.DateOfBirth"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.PhoneNumber" class="form-label">Phone Number: </label>
            <input asp-for="@Model.PhoneNumber" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.PhoneNumber"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.UCN" class="form-label">UCN: </label>
            <input asp-for="@Model.UCN" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.UCN"></span>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

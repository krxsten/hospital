
<div class="mb-3">

    <h2 style="text-align:center">Pending Doctors</h2>
</div>
<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Doctors</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            @foreach (var d in ViewBag.Doctors)
            {
                @d.User.FirstName @d.User.LastName
                <form asp-action="AcceptDoctor" method="post">
                    <input type="hidden" name="id" value="@d.UserId" />
                    <button class="btn btn-success">Accept</button>
                </form>
            }
        </tr>
    </tbody>
</table>




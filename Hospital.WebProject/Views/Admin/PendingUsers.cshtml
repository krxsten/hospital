
<div class="mb-3">

    <h2 style="text-align:center">———— Pending Doctors & Nurses————</h2>
</div>
<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Doctors</th>
            <th>Nurses</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in ViewBag.Doctors)
        {
            <tr>
                <td>@d.User.FirstName @d.User.LastName </td>
                <form asp-action="AcceptDoctor" method="post">
                    <input type="hidden" name="id" value="@d.UserId" />
                    <button class="btn btn-success">Accept</button>
                </form>
            </tr>
        }
        @foreach (var d in ViewBag.Nurses)
        {
            <tr>
                <td>@d.User.FirstName @d.User.LastName </td>
                <form asp-action="AcceptNurse" method="post">
                    <input type="hidden" name="id" value="@d.UserId" />
                    <button class="btn btn-success">Accept</button>
                </form>
            </tr>
        }
    </tbody>
</table>




<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

        .glass-panel label,
        .glass-panel h4,
        .page-title-white {
            color: #ffffff !important;
            font-weight: 700;
        }

    .custom-input::placeholder {
        color: #ffffff !important;
    }
    .custom-input {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        color: #ffffff !important;
        border-radius: 12px;
        padding: 12px;
    }

        .custom-input:focus {
            background-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
            outline: none;
        }

    .shift-option {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px;
        padding: 12px 20px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: block;
        color: white;
    }

        .shift-option:hover {
            background: rgba(255, 255, 255, 0.15);
        }

    .btn-check:checked + .shift-option {
        color: #000000;
        border-color: #ffffff;
        font-weight: 600;
    }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 50px;
        padding: 12px 40px;
        text-transform: uppercase;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-primary-white:hover {
            background-color: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

    .text-danger {
        color: #ff6b6b !important;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

@using Hospital.WebProject.ViewModels.Shift
@model ShiftIndexViewModel

@if (User.IsInRole("Admin"))
{
    <div class="page-header-custom text-center">
        <h2 class="page-title-white">Edit Shift</h2>
        <div class="title-divider"></div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="glass-panel">
                    <h4 class="mb-4"><i class="bi bi-clock-history me-2"></i>Modify Shift Details</h4>

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="ID" />

                        <div class="mb-4">
                            <label class="form-label d-block mb-3">Shift Type</label>

                            <input type="radio" class="btn-check" asp-for="Type" value="Day shift" id="dayShift">
                            <label class="shift-option" for="dayShift">Day Shift</label>

                            <input type="radio" class="btn-check" asp-for="Type" value="Afternoon shift" id="afternoonShift">
                            <label class="shift-option" for="afternoonShift">Afternoon Shift</label>

                            <input type="radio" class="btn-check" asp-for="Type" value="Night shift" id="nightShift">
                            <label class="shift-option" for="nightShift">Night Shift</label>

                            <span class="text-danger" asp-validation-for="@Model.Type"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="@Model.StartTime" class="form-label">Start Time</label>
                                <input asp-for="@Model.StartTime" type="time" class="form-control custom-input" />
                                <span class="text-danger" asp-validation-for="@Model.StartTime"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="@Model.EndTime" class="form-label">End Time</label>
                                <input asp-for="@Model.EndTime" type="time" class="form-control custom-input" />
                                <span class="text-danger" asp-validation-for="@Model.EndTime"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5 pt-3 border-top border-white border-opacity-25">
                            <button type="submit" class="btn btn-primary-white flex-grow-1">Update Shift</button>
                            <a asp-action="Index" class="btn btn-primary-white flex-grow-1">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@using Hospital.WebProject.ViewModels.Shift
@model List<ShiftViewModel>
<div class="mb-3">
    <h2 style="text-align:center">Shifts</h2>
</div>
<table class="table">
    <thead>
        <tr>
            <th scope="col">Type</th>
            <th scope="col">Start time</th>
            <th scope="col">End time</th>
            <th scope="col"></th>
        </tr>
    </thead>
    <tbody class="table-group-divider">
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Type</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-warning me-2">Edit</a>
                        <form asp-action="Delete" asp-route-id="@item.ID" method="post" class="d-inline">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">Create</a>
    </div>
}

<div class="mb-3">
    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Back</a>
</div>

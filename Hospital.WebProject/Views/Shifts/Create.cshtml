<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Shift
@model ShiftCreateViewModel
@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Shifts ————</h2>
    </div>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="@Model.Type" class="form-label">Type: </label>
            <br />
            <input type="radio" asp-for="Type" name="type" value="MorningShift"/>Morning shift
            <br />
            <input type="radio" asp-for="Type" name="type" value="Afternoon shift" />Afternoon shift
            <br />
            <input type="radio" asp-for="Type" name="type" value="NightShift"/>Night shift
            <br />
            <input type="radio" asp-for="Type" name="type" value="EmergencyShift" />Emergency shift
            <br />
            <input type="radio" asp-for="Type" name="type" value="WeekendShift" />Weekend shift
        </div>
        <span class="text-danger" asp-validation-for="@Model.Type"></span>
        <div class="mb-3">
            <label asp-for="@Model.StartTime" class="form-label">Start time: </label>
            <input asp-for="@Model.StartTime" type="time" step="60" class="form-control"/>
            <span class="text-danger" asp-validation-for="@Model.StartTime"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.EndTime" class="form-label">End time: </label>
            <input asp-for="@Model.EndTime" type="time" step="60" class="form-control" />
            <span class="text-danger" asp-validation-for="@Model.EndTime"></span>
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
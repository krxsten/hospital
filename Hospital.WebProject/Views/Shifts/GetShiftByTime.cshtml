<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

    .shift-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid #ffffff;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
    }

        .shift-card:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 30px rgba(255, 255, 255, 0.15);
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 10px;
        border: none;
    }

    .custom-search-input {
        height: 50px;
        border-radius: 10px;
        background: rgba(255,255,255,0.1) !important;
        color: white !important;
        border: 1px solid #ffffff !important;
    }

        .custom-search-input::-webkit-calendar-picker-indicator {
            filter: invert(1);
        }
</style>

@using Hospital.WebProject.ViewModels.Shift
@model List<ShiftIndexViewModel>

<div class="page-header-custom text-center">
    <h2 class="page-title-white text-white">Shift Search</h2>
    <div class="title-divider"></div>
</div>

<div class="container pb-5">
    <div class="glass-panel mb-5">
        <form method="get" asp-action="GetShiftByTime">
            <div class="row g-3">
                <div class="col-md-8">
                    <input type="time" name="time" class="form-control custom-search-input" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary-white flex-grow-1" style="height: 50px;">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light d-flex align-items-center px-4"
                       style="border-radius: 10px;">
                        Back
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="row" id="shiftResultsContainer">
        @if (Model != null && Model.Any())
        {
            @foreach (var shift in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="shift-card p-4">
                        <h4 class="text-white fw-bold mb-3">@shift.Type</h4>
                        <p class="text-white-50 mb-2">
                            <strong class="text-white">Start Time:</strong> @shift.StartTime
                        </p>
                        <p class="text-white-50 mb-0">
                            <strong class="text-white">End Time:</strong> @shift.EndTime
                        </p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-white-50 fs-5">Search to see matching shifts.</p>
            </div>
        }
    </div>
</div>
<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 2px solid #ffffff;
        border-radius: 30px;
        padding: 40px;
    }

    .shift-result-card {
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid #ffffff;
        border-radius: 20px;
        transition: all 0.3s ease;
        color: #ffffff;
    }

        .shift-result-card:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-5px);
        }

    .custom-input {
        background-color: transparent !important;
        border: 1px solid #ffffff !important;
        color: #ffffff !important;
        border-radius: 12px;
        padding: 12px;
        height: 50px;
    }

        .custom-input:focus {
            background-color: rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
        }

    .btn-primary-white {
        background-color: #ffffff !important;
        color: #000000 !important;
        font-weight: 800;
        border-radius: 12px;
        border: none;
        transition: all 0.3s ease;
        text-transform: uppercase;
    }

        .btn-primary-white:hover {
            background-color: rgba(255, 255, 255, 0.9);
            transform: translateY(-2px);
        }

    .time-badge {
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.9rem;
    }
</style>

@using Hospital.WebProject.ViewModels.Shift
@model List<ShiftIndexViewModel>

<div class="page-header-custom text-center">
    <h2 class="page-title-white">Shift Search</h2>
    <div class="title-divider"></div>
</div>

<div class="container pb-5">
    <div class="glass-panel mb-5">
        <form method="get" asp-action="GetShiftByTime">
            <div class="row g-3 align-items-end">
                <div class="col-md-7">
                    <label class="text-white mb-2 fw-bold small text-uppercase">Check Shift Availability by Time</label>
                    <input type="time" name="time" class="form-control custom-input" required />
                </div>
                <div class="col-md-5 d-flex gap-2">
                    <button type="submit" class="btn btn-primary-white flex-grow-1" style="height: 50px;">
                        <i class="bi bi-search me-2"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light d-flex align-items-center justify-content-center px-4"
                       style="height: 50px; border-radius: 12px; flex-grow: 1;">
                        Back
                    </a>
                </div>
            </div>
        </form>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row justify-content-center g-4">
            @foreach (var shift in Model)
            {
                <div class="col-lg-6">
                    <div class="shift-result-card p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <i class="bi bi-clock-fill text-dark fs-4"></i>
                            </div>
                            <div>
                                <h4 class="mb-0 fw-bold">@shift.Type</h4>
                                <span class="text-white-50 small">Active Shift Found</span>
                            </div>
                        </div>

                        <div class="border-top border-white border-opacity-10 pt-4">
                            <div class="row text-center">
                                <div class="col-6 border-end border-white border-opacity-10">
                                    <p class="text-white-50 small text-uppercase mb-1">Start Time</p>
                                    <span class="time-badge">@shift.StartTime</span>
                                </div>
                                <div class="col-6">
                                    <p class="text-white-50 small text-uppercase mb-1">End Time</p>
                                    <span class="time-badge">@shift.EndTime</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-white-50" style="font-size: 4rem;"></i>
            <h4 class="text-white-50 mt-3">No shifts scheduled for the selected time.</h4>
        </div>
    }
</div>
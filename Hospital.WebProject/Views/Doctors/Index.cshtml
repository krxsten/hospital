<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Doctor
@model List<DoctorIndexViewModel>

<div class="mb-3">
    <h2 style="text-align:center">———— Doctors ————</h2>
</div>

<div class="mb-3 d-flex justify-content-end" style="font-family: 'Times New Roman'; font-size: 24px">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">+ Create</a>
    }
    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary ms-3">← Back</a>
</div>

<div class="doctor-grid">
    @foreach (var doctor in Model)
    {
        <div class="doctor-card">
            <img src="@doctor.ImageURL" class="doctor-image" />

            <h5 class="doctor-name">
                @doctor.UserName
            </h5>

            <p class="doctor-field">
                <strong>Specialization:</strong> @doctor.SpecializationName
            </p>

            <p class="doctor-field">
                <strong>Shift:</strong> @doctor.ShiftName
            </p>

            <p class="doctor-field">
                <strong>Status:</strong>
                @if (doctor.IsAccepted)
                {
                    <span class="badge-accepted">Accepted</span>
                }
                else
                {
                    <span class="badge-pending">Pending</span>
                }
            </p>

            <div class="doctor-actions">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@doctor.ID" class="btn btn-warning mb-3">Edit</a>

                    <form asp-action="Delete" asp-route-id="@doctor.ID" method="post" style="display:inline">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                }
            </div>
        </div>
    }
</div>

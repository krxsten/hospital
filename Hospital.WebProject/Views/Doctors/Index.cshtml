<style>
    .staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 30px;
        padding: 20px 0;
    }

    .staff-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        text-align: center;
    }

        .staff-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }
    .staff-image-wrapper {
        position: relative;
        padding: 20px;
        background: #f8fafc;
    }

    .staff-image {
        width: 150px;
        height: 150px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .badge-status {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-accepted {
        background: #dcfce7;
        color: #15803d;
        border: 1px solid #bbf7d0;
    }

    .status-pending {
        background: #fef9c3;
        color: #a16207;
        border: 1px solid #fef08a;
    }

    .staff-info {
        padding: 0 20px 20px 20px;
    }

    .staff-name {
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 5px;
    }

    .staff-specialty {
        color: #0d6efd;
        font-weight: 600;
        font-size: 14px;
    }

    .staff-shift {
        font-size: 13px;
        color: #64748b;
    }

    .btn-staff-action {
        width: 100px !important;
        height: 38px !important;
        display: inline-flex !important;
        align-items: center;
        justify-content: center;
        font-weight: 550 !important;
        border-radius: 10px !important;
        font-size: 13px !important;
        border: none !important;
    }
</style>

@using Hospital.WebProject.ViewModels.Doctor
@model List<DoctorIndexViewModel>

<div class="container pb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Medical Specialists</h2>
        <div class="mx-auto bg-white rounded-pill mt-2" style="height: 4px; width: 60px;"></div>
    </div>

    <div class="d-flex justify-content-end align-items-center mb-4 gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">+ Register Doctor</a>
        }
        <a asp-action="FilterBySpecialization" class="btn btn-light border rounded-pill px-4 shadow-sm">Search By Specialization</a>
        <a asp-action="SortByFirstName" class="btn btn-light border rounded-pill px-4 shadow-sm">Sort A-Z</a>
        <a asp-action="Index" asp-controller="Home" class="btn btn-secondary rounded-pill px-4 shadow-sm">Back</a>
    </div>

    <div class="staff-grid">
        @foreach (var doctor in Model)
        {
            @if (doctor.IsAccepted)
            {
                <div class="staff-card shadow-sm">
                    <div class="staff-image-wrapper">
                        <span class="badge-status status-accepted">Active</span>
                        <img src="@doctor.ImageURL" class="staff-image" />
                    </div>

                    <div class="staff-info">
                        <h4 class="staff-name">Dr. @doctor.UserName</h4>
                        <div class="staff-specialty mb-2">@doctor.SpecializationName</div>
                        <div class="staff-shift"><i class="bi bi-clock"></i> @doctor.ShiftName</div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex justify-content-center gap-2 mt-4 pt-3 border-top">
                                <a asp-action="Edit" asp-route-id="@doctor.ID" class="btn btn-warning btn-staff-action">Edit</a>
                                <form asp-action="Delete" asp-route-id="@doctor.ID" method="post" class="m-0"
                                      onsubmit="return confirm('Are you sure you want to delete Dr. @doctor.UserName?')">
                                    <button type="submit" class="btn btn-danger btn-staff-action">Delete</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<hr class="my-5 opacity-25">



@using Hospital.WebProject.ViewModels.Doctor
@model DoctorEditViewModel

@if (User.IsInRole("Admin"))
{
    <div class="mb-3">
        <h2 style="text-align:center">———— Doctors ————</h2>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="ID" />

        <div class="mb-3">
            <label asp-for="DoctorName" class="form-label">Doctor Name:</label>
            <input asp-for="DoctorName" class="form-control" />
            <span class="text-danger" asp-validation-for="DoctorName"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SpecializationId" class="form-label">Specialization:</label>
            <select asp-for="SpecializationId" asp-items="ViewBag.Specialization" class="form-select"></select>
            <span class="text-danger" asp-validation-for="SpecializationId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ShiftId" class="form-label">Shift:</label>
            <select asp-for="ShiftId" asp-items="ViewBag.Shift" class="form-select"></select>
            <span class="text-danger" asp-validation-for="ShiftId"></span>
        </div>

        <div class="mb-3">
            <label asp-for="File" class="form-label">Upload Image:</label>
            <input asp-for="File" type="file" accept="image/*" class="form-control" />
            <span class="text-danger" asp-validation-for="File"></span>
        </div>

        @if (!string.IsNullOrEmpty(Model.ExistingImage))
        {
            <div class="mb-3">
                <p>Current image:</p>
                <img src="@Model.ExistingImage" width="200" />
            </div>
        }

        <div class="mb-3">
            <button type="submit" class="btn btn-success">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>

    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
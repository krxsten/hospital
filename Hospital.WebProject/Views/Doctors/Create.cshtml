<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Doctor
@model DoctorCreateViewModel
@if (User.IsInRole("Admin"))
{
    <form asp-controller="Doctors" asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="UserID" class="form-label">Doctor: </label>
            <select asp-for="UserID" asp-items="ViewBag.Users" class="form-select">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="SpecializationID" class="form-label">Specialization</label>
            <select asp-for="SpecializationID" asp-items="ViewBag.Specialization" class="form-select">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="ShiftID" class="form-label">Shift</label>
            <select asp-for="ShiftID" asp-items="ViewBag.Shift" class="form-select">
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Image" class="form-label">Image URL</label>
            <input asp-for="Image" class="form-control" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Submit</button>
            <a asp-action="Index" class="btn btn-secondary" style="display:inline">Back</a>
        </div>
    </form>
}
<style>
    .card {
        border: none;
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card img {
            border-left: 1px solid rgba(0,0,0,0.05);
        }

    .back-btn {
        background: rgba(255,255,255,0.08);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .back-btn:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(147, 197, 253, 0.5);
            transform: translateX(-3px);
            color: #e0f2fe;
        }</style>
<link rel="stylesheet" href="/css/styles.css">
@using Hospital.WebProject.ViewModels.Doctor
@model List<DoctorIndexViewModel>

<h2 class="mb-4 text-white">Doctors Sorted by First Name</h2>
<div class="mb-4">
    <a asp-action="Index"
       class="btn back-btn d-inline-flex align-items-center gap-2">
         Back
    </a>
</div>

<div class="row">
    @foreach (var n in Model)
    {
        <div class="col-lg-6 col-xl-4 mb-4">
            <div class="card shadow-sm h-100 overflow-hidden">
                <div class="row g-0 h-100">
                    <div class="col-8">
                        <div class="card-body d-flex flex-column justify-content-center h-100">
                            <p class="card-title mb-1 text-primary">@n.UserName</p>
                            <p class="card-text text-muted mb-0">
                                <small>@n.SpecializationName</small>
                            </p>
                        </div>
                    </div>
                    <div class="col-4">
                        <img src="@n.ImageURL"
                             alt="@n.UserName"
                             class="img-fluid h-100 w-100"
                             style="object-fit: cover; min-height: 120px;" />
                    </div>
                </div>
            </div>
        </div>
    }
</div>
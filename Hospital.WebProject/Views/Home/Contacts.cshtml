@page
<style>
    .contact-container {
        max-width: 900px;
        margin: 50px auto;
        padding: 30px;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        color: white;
    }

        .contact-container h2 {
            text-align: center;
            margin-bottom: 30px;
            font-family: 'Georgia', 'Times New Roman', serif;
            font-size: 2.2rem;
            position: relative;
        }

            .contact-container h2::after {
                content: "";
                display: block;
                width: 80px;
                height: 3px;
                background: linear-gradient(to right, #ffffff, #bbdefb);
                margin: 10px auto 0;
                border-radius: 2px;
            }

    .contact-form input,
    .contact-form textarea {
        width: 100%;
        padding: 12px 15px;
        margin-bottom: 15px;
        border: none;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.1);
        color: white;
        font-size: 1rem;
    }

        .contact-form input::placeholder,
        .contact-form textarea::placeholder {
            color: rgba(255, 255, 255, 0.7);
        }

    .contact-form button {
        padding: 12px 25px;
        background: #007bff;
        border: none;
        border-radius: 8px;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
    }

        .contact-form button:hover {
            background: #0056b3;
        }

    .contact-info {
        margin-top: 30px;
        font-size: 1.05rem;
        line-height: 1.6;
    }

        .contact-info p {
            margin-bottom: 10px;
        }

    .contact-map {
        margin-top: 30px;
        width: 100%;
        height: 300px;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.4);
    }

        .contact-map iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }
</style>
@model Hospital.WebProject.Views.Home.ContactsModel
@{
    <div class="col-md-6 contact-info">
        <h4>Get in Touch</h4>
        <p><strong>Address:</strong> 123 Saint Anna Street, City, Country</p>
        <p><strong>Phone:</strong> +1 (555) 123-4567</p>
        <p><strong>Email:</strong> info@saintanna.com</p>
        <p><strong>Working Hours:</strong> Mon - Sat: 8:00 AM - 6:00 PM</p>

        <div class="contact-map">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!..."
                    allowfullscreen="" loading="lazy">
            </iframe>
        </div>
    </div>
}

@{
    ViewData["Title"] = "Home Page";
}
<style>
    .history-text {
        max-width: 520px;
        text-align: left;
        color: white;
        font-family: 'Georgia', 'Cambria', serif;
        line-height: 1.8;
        letter-spacing: 0.5px;
    }

        .history-text h2 {
            font-size: 2.2rem;
            margin-bottom: 20px;
            font-weight: 600;
            letter-spacing: 1px;
            position: relative;
        }

            .history-text h2::after {
                content: "";
                display: block;
                width: 60px;
                height: 3px;
                background: linear-gradient(to right, #ffffff, #bbdefb);
                margin-top: 10px;
                border-radius: 2px;
            }

        .history-text p {
            font-size: 1.05rem;
            opacity: 0.95;
            margin-bottom: 15px;
        }

            .history-text p::first-letter {
                font-size: 1.8rem;
                font-weight: bold;
                color: #e3f2fd;
            }
    .content-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 40px;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    .image-frame {
        width: 400px;
        height: 400px;
        border-radius: 30%;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.4);
        border: 5px solid rgba(255,255,255,0.4);
    }

        .image-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .image-frame {
        transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

        .image-frame:hover {
            transform: scale(1.03);
            box-shadow: 0 12px 35px rgba(255,255,255,0.3);
        }
    .history-text {
        max-width: 500px;
        text-align: left;
        color: white;
        font-family: Cambria
    }

        .history-text h2 {
            margin-bottom: 15px;
        }

    .hero-text {
        text-align: center;
        margin-top: 40px;
        color: white;
    }

    .main-title {
        font-family: 'Georgia', 'Cambria', serif;
        font-size: 3.5rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
        position: relative;
    }
        .main-title::after {
            content: "";
            display: block;
            width: 120px;
            height: 3px;
            margin: 15px auto 0;
            border-radius: 2px;
        }

    .subtitle {
        font-family: 'Georgia', serif;
        font-size: 1.4rem;
        font-style: italic;
        letter-spacing: 1px;
        opacity: 0.9;
    }
</style>

<div class="text-center hero-titlesubtitle">
    <h1 class="display-3 text-white main-title" style="font-family: 'Cambria'">"Saint Anna" Medical Center </h1>
    <p class="display-6 text-white subtitle" style="font-family: 'Cambria'">Where advanced medicine meets exceptional care.</p>
    <div class="content-wrapper">
        <div class="image-frame">
            <img src="~/img/index.jpg" alt="Saint Anna Hospital" />
        </div>
        <div class="history-text">
            <h2>Our History</h2>
            <p>
                "Saint Anna" Medical Center has a long-standing tradition of excellence in healthcare.
                Established with the mission to provide high-quality medical services, the hospital
                has grown into a modern healthcare institution equipped with advanced technologies
                and highly trained specialists.
            </p>
            <p>
                Over the years, it has become a trusted name in patient care, combining innovation,
                compassion, and professionalism to serve the community. Today, "Saint Anna" continues
                to evolve while maintaining its commitment to saving lives and improving health.
            </p>
        </div>
    </div>
</div>
<div class="container mt-5 text-white">
    <h2 class="text-center mb-4">Our Services</h2>

    <div class="row text-center">
        <div class="col-md-4">
            <div class="p-4 border rounded shadow-sm bg-dark">
                <h4>Cardiology</h4>
                <p>Advanced heart care with modern diagnostics and treatment.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 border rounded shadow-sm bg-dark">
                <h4>Neurology</h4>
                <p>Comprehensive care for brain and nervous system disorders.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 border rounded shadow-sm bg-dark">
                <h4>Emergency Care</h4>
                <p>24/7 emergency services with rapid response teams.</p>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5 text-center text-white">
    <div class="row">
        <div class="col-md-4">
            <h1>25+</h1>
            <p>Years of Experience</p>
        </div>
        <div class="col-md-4">
            <h1>100+</h1>
            <p>Qualified Doctors</p>
        </div>
        <div class="col-md-4">
            <h1>10K+</h1>
            <p>Happy Patients</p>
        </div>
    </div>
</div>


<div class="container mt-5 text-center">
    <div class="p-5 rounded" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
        <h2 class="text-white mb-3">Need Medical Assistance?</h2>
        <p class="text-white mb-4">Our specialists are here to help you anytime.</p>

        <a asp-action="Create" asp-controller="Checkup" class="btn btn-primary btn-lg me-2">Book Appointment</a>
        <a href="/Home/Contacts" class="btn btn-outline-light btn-lg">Contact Us</a>
    </div>
</div>

<style>
    body {
        background: linear-gradient(180deg, #0f172a 0%, #162033 45%, #1e293b 100%);
    }

    .main-title {
        font-size: 4.2rem;
        font-weight: 900;
        letter-spacing: -1px;
        background: linear-gradient(to right, #ffffff, #bfdbfe);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.7rem;
    }

    .subtitle {
        font-size: 1.15rem;
        font-weight: 400;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.78);
        margin-bottom: 1.5rem;
    }

    .hero-section {
        padding: 39px 0 30px 0;
    }

    .hero-wrapper {
        background: linear-gradient(135deg, rgba(255,255,255,0.10), rgba(255,255,255,0.04));
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 40px;
        padding: 55px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.20);
        position: relative;
        overflow: hidden;
    }

        .hero-wrapper::before {
            content: "";
            position: absolute;
            top: -80px;
            right: -80px;
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(96,165,250,0.25) 0%, rgba(96,165,250,0) 70%);
            pointer-events: none;
        }

        .hero-wrapper::after {
            content: "";
            position: absolute;
            bottom: -100px;
            left: -80px;
            width: 240px;
            height: 240px;
            background: radial-gradient(circle, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0) 70%);
            pointer-events: none;
        }

    .floating-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(10px);
        opacity: 0.45;
        pointer-events: none;
        animation: floatOrb 8s ease-in-out infinite;
    }

        .floating-orb.orb-1 {
            width: 140px;
            height: 140px;
            top: 40px;
            left: 30px;
            background: radial-gradient(circle, rgba(96,165,250,0.45) 0%, rgba(96,165,250,0.05) 70%);
        }

        .floating-orb.orb-2 {
            width: 180px;
            height: 180px;
            bottom: 60px;
            right: 40px;
            background: radial-gradient(circle, rgba(255,255,255,0.20) 0%, rgba(255,255,255,0.03) 70%);
            animation-delay: 1.5s;
        }

        .floating-orb.orb-3 {
            width: 100px;
            height: 100px;
            top: 55%;
            left: 48%;
            background: radial-gradient(circle, rgba(59,130,246,0.35) 0%, rgba(59,130,246,0.02) 70%);
            animation-delay: 3s;
        }

    .emoji-bubble {
        position: absolute;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 62px;
        height: 62px;
        border-radius: 50%;
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.18);
        backdrop-filter: blur(10px);
        font-size: 1.6rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.18);
        z-index: 3;
        animation: floatEmoji 6s ease-in-out infinite;
    }

        .emoji-bubble.one {
            top: 30px;
            right: 28px;
        }

        .emoji-bubble.two {
            bottom: 30px;
            left: 28px;
            animation-delay: 1.5s;
        }

        .emoji-bubble.three {
            top: 48%;
            right: 46%;
            width: 54px;
            height: 54px;
            font-size: 1.3rem;
            animation-delay: 3s;
        }

    @@keyframes floatEmoji {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes floatOrb {
        0% {
            transform: translateY(0px) translateX(0px);
        }

        50% {
            transform: translateY(-18px) translateX(10px);
        }

        100% {
            transform: translateY(0px) translateX(0px);
        }
    }

    .hero-content {
        max-width: 560px;
        margin: 0 auto;
        text-align: center;
        position: relative;
        z-index: 2;
    }

    .hero-description {
        color: #dbeafe;
        font-size: 1.08rem;
        line-height: 1.9;
        max-width: 500px;
        margin: 0 auto 2rem auto;
    }

    .hero-image-container {
        position: relative;
        width: 100%;
        max-width: 550px;
        margin: 0 auto;
        border-radius: 34px;
        overflow: hidden;
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.28);
        border: 1px solid rgba(255,255,255,0.14);
        transition: transform 0.35s ease, box-shadow 0.35s ease;
        z-index: 2;
    }

        .hero-image-container:hover {
            transform: translateY(-6px) scale(1.01);
            box-shadow: 0 28px 55px rgba(0, 0, 0, 0.35);
        }

        .hero-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.14);
        color: #e0f2fe;
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 0.95rem;
        margin-bottom: 1.4rem;
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        position: relative;
        overflow: hidden;
    }

        .hero-badge::after {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 80%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
            transform: skewX(-20deg);
        }

  

    .hero-info-card {
        position: absolute;
        bottom: 18px;
        left: 18px;
        right: 18px;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 22px;
        padding: 18px 22px;
        animation: pulseCard 3.5s ease-in-out infinite;
    }

        .hero-info-card h4 {
            color: white;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .hero-info-card p {
            margin: 0;
            color: rgba(255,255,255,0.75);
            font-size: 0.95rem;
        }

    .mini-floating-card {
        position: absolute;
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 18px;
        padding: 12px 16px;
        color: white;
        box-shadow: 0 12px 24px rgba(0,0,0,0.18);
        z-index: 4;
        animation: miniCardFloat 5.5s ease-in-out infinite;
    }

        .mini-floating-card.top-card {
            top: 16px;
            left: 16px;
        }

        .mini-floating-card.side-card {
            top: 100px;
            right: -15px;
            animation-delay: 1.5s;
        }

        .mini-floating-card strong {
            display: block;
            font-size: 0.95rem;
        }

        .mini-floating-card span {
            font-size: 0.8rem;
            color: rgba(255,255,255,0.75);
        }

    @@keyframes miniCardFloat {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    @@keyframes pulseCard {
        0%, 100% {
            box-shadow: 0 0 0 rgba(255,255,255,0.0);
        }

        50% {
            box-shadow: 0 0 25px rgba(255,255,255,0.08);
        }
    }

    .scroll-indicator {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,0.75);
        font-size: 0.85rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 25px;
    }

        .scroll-indicator i {
            animation: bounceDown 1.8s infinite;
        }

    @@keyframes bounceDown {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(8px);
        }
    }

    .trust-strip {
        margin-top: 22px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
    }

    .trust-pill {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        color: #e2e8f0;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 40px;
        transition: transform 0.3s ease;
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    }

    .hospital-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        grid-auto-rows: 250px;
        gap: 20px;
        margin: 50px 0;
    }

    .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .gallery-item:hover img {
            transform: scale(1.1);
        }

    .gallery-label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 20px;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .section-title {
        color: white;
        font-weight: 800;
        text-align: center;
        margin-bottom: 1rem;
    }

        .section-title .emoji {
            margin-right: 10px;
        }

    .facility-info-strip {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 20px;
    }

    .facility-chip {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 22px;
        padding: 18px 20px;
        color: white;
        display: flex;
        align-items: center;
        gap: 14px;
    }

        .facility-chip .emoji {
            font-size: 1.7rem;
        }

    .stat-box h1 {
        font-size: 3.5rem;
        font-weight: 900;
        color: white;
        margin-bottom: 0;
    }

    .stat-box p {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.9rem;
        color: #94a3b8;
    }

    .service-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 30px;
        border-radius: 24px;
        width: 280px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        position: relative;
        overflow: hidden;
    }


        .service-card:hover {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(255,255,255,0.35);
            transform: translateY(-10px);
        }

        .service-card h4 {
            color: white;
            font-weight: 700;
        }

        .service-card i {
            transition: transform 0.35s ease;
        }

        .service-card:hover i {
            transform: scale(1.15) rotate(-6deg);
        }

    .service-emoji {
        font-size: 1.8rem;
        margin-bottom: 12px;
    }

   


    @@media (max-width: 991px) {
        .hero-wrapper {
            padding: 35px 24px;
            border-radius: 30px;
        }

        .main-title {
            font-size: 3rem;
        }

        .hero-section {
            padding-top: 10px;
        }

        .hero-image-container {
            margin-top: 5px;
        }

        .mini-floating-card.side-card {
            right: 10px;
            top: 70px;
        }

        .emoji-bubble.three {
            display: none;
        }
    }
</style>

<div class="container pb-0 mt-0 ">
    <div class="hero-section">
        <div class="hero-wrapper">
           
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="hero-content text-lg-start text-center mx-lg-0 fade-up">
                         <div class="hero-badge">
                            <i class="bi bi-shield-check"></i>Trusted Care Since 2007
                        </div> 

                        <h1 class="main-title">Saint Anna</h1>
                        <p class="subtitle">Advanced Medicine. Exceptional Care.</p>

                        <p class="hero-description mx-lg-0">
                            Experience modern healthcare in a warm and welcoming environment, with expert doctors,
                            innovative treatment, and compassionate support for every patient.
                        </p>

                        <div class="trust-strip">
                            <div class="trust-pill"><span>🏥</span> Modern Facility</div>
                            <div class="trust-pill"><span>👩‍⚕️</span> Expert Specialists</div>
                            <div class="trust-pill"><span>🚑</span> Emergency Support</div>
                        </div>

                       
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="hero-image-container fade-up-delay-1">
                        <img src="~/img/index.jpg" class="img-fluid" alt="Hospital Main" />
                        <div class="hero-info-card">
                            <h4>24/7 Emergency Care</h4>
                            <p>Always ready to support you with immediate medical attention.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="my-5 pt-4 fade-up-delay-1">
        <h2 class="section-title">Explore Our Facility</h2>

        <div class="hospital-gallery">
            <div class="gallery-item" style="grid-column: span 2; grid-row: span 2;">
                <div class="gallery-label">Main Diagnostic Wing</div>
                <img src="https://res.cloudinary.com/dyoxqki3d/image/upload/q_auto/f_auto/v1775203936/S23683_00_SCH_Forest_B_N390_printmedium-scaled_x1ajv0.jpg" alt="Diagnostic Wing" />
            </div>
            <div class="gallery-item">
                <div class="gallery-label">Emergency</div>
                <img src="https://res.cloudinary.com/dyoxqki3d/image/upload/q_auto/f_auto/v1775204465/TBO_9315Trauma-scaled_fnfubs.jpg" alt="Emergency" />
            </div>
            <div class="gallery-item">
                <div class="gallery-label">Operating Theater</div>
                <img src="https://res.cloudinary.com/dyoxqki3d/image/upload/q_auto/f_auto/v1775204505/Hybrid-OR-1024x683_e010je.jpg" alt="Operating Theater" />
            </div>
            <div class="gallery-item" style="grid-column: span 2;">
                <div class="gallery-label">Premium Recovery Suites</div>
                <img src="https://res.cloudinary.com/dyoxqki3d/image/upload/q_auto/f_auto/v1775204550/23-0192857_yxakti.jpg" alt="Recovery Suites" />
            </div>
        </div>
    </div>

    <div class="glass-panel text-center my-5 fade-up-delay-2">
        <div class="row g-4">
            <div class="col-md-4 stat-box">
                <h1>25+</h1>
                <p>Years of Excellence</p>
            </div>
            <div class="col-md-4 stat-box">
                <h1>100+</h1>
                <p>Expert Doctors</p>
            </div>
            <div class="col-md-4 stat-box">
                <h1>10K+</h1>
                <p>Lives Impacted</p>
            </div>
        </div>
    </div>
        
    <div class="text-center py-5" id="services">
        <h2 class="section-title"><span class="emoji"></span>Specialized Services</h2>

        <div class="d-flex flex-wrap justify-content-center gap-4">
            <div class="service-card">
                <div class="service-emoji">❤️</div>
                <i class="bi bi-heart-pulse text-primary fs-1 mb-3"></i>
                <h4>Cardiology</h4>
                <p class="text-white small">Advanced heart care and surgical diagnostics.</p>
            </div>
            <div class="service-card">
                <div class="service-emoji">🧠</div>
                <i class="bi bi-brain text-primary fs-1 mb-3"></i>
                <h4>Neurology</h4>
                <p class="text-white small">Specialized brain and nervous system recovery.</p>
            </div>
            <div class="service-card">
                <div class="service-emoji">⚡</div>
                <i class="bi bi-lightning-charge text-primary fs-1 mb-3"></i>
                <h4>ER Response</h4>
                <p class="text-white small">Immediate 24/7 rapid response trauma unit.</p>
            </div>
        </div>
    </div>

    <div class="glass-panel text-center mt-5 py-5" style="border: 2px solid #3b82f6;">
        <h2 class="text-white fw-bold mb-3"> Need Medical Assistance?</h2>
        <p class="text-white mb-4 fs-5">Our specialists are available for consultations and emergency care.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            @if (User.IsInRole("Patient"))
            {
                <a href="@Url.Action("Create", "Checkup")" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow">
                    📅 Book Appointment
                </a>
            }
            <a href="/Home/Contacts" class="btn btn-outline-light btn-lg rounded-pill px-5">
                📞 Contact Us
            </a>
            <a href="/Home/History" class="btn btn-outline-light btn-lg rounded-pill px-5">
                📜 Our History
            </a>
        </div>
    </div>
</div>